# Old files
archive

# Python
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
env/
venv/
ENV/

# Byte-compiled / optimized / DLL files
*.pyc
*.pyo
*.pyd

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
download/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
nosetests.xml
coverage.xml
*,cover

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer
*.log

# C extensions
*.so

# Compiled object files
*.o
*.obj

# Firmware build artifacts
*/build/
*.lst
*.bin
*.hex

# macOS
.DS_Store

# Editor files
*.swp
*~

# Misc
err.txt

# Node.js (for web components)
node_modules/

# temporary files
*.tmp

# ignore local settings
local_settings.py

# vscode
.vscode